{
  "name": "venezuelan-game",
  "version": "1.0.0",
  "description": "Andsiosa's Creative Quest — a cute retro side-scrolling platformer built with Phaser, Vite, and TypeScript",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview --host 0.0.0.0",
    "phone:tunnel": "bash scripts/phone-tunnel.sh",
    "assets:manifest": "node scripts/sync-figma-world-assets.mjs manifest",
    "assets:download": "node scripts/sync-figma-world-assets.mjs download",
    "assets:export": "node scripts/sync-figma-world-assets.mjs export",
    "assets:list": "node scripts/sync-figma-world-assets.mjs list",
    "assets:sync": "node scripts/sync-figma-world-assets.mjs download && node scripts/sync-figma-world-assets.mjs manifest",
    "assets:layout": "node scripts/build-level-layout.mjs",
    "assets:layout:mobile": "node scripts/extract-figma-mobile-layout.mjs",
    "assets:platforms": "node scripts/sync-figma-platform-art.mjs",
    "assets:character": "node scripts/sync-figma-character-art.mjs",
    "assets:enemy": "node scripts/sync-figma-enemy-art.mjs",
    "assets:screens": "node scripts/sync-figma-screen-art.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.14"
  },
  "private": true,
  "type": "module"
}
